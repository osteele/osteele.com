---
import { projectsData } from "@/data/projects";
import Layout from "../layouts/Layout.astro";

const recentProjects = projectsData.projects
	.filter((p) => !p.isArchived && p.dateModified)
	.sort((a, b) => b.dateModified?.getTime() - a.dateModified?.getTime())
	.slice(0, 3);
---

<Layout
    title="Oliver Steele"
    description="Oliver Steele - Software engineer, educator, and maker"
>
    <div class="relative isolate">
        <div class="mx-auto max-w-4xl px-6 py-6 lg:px-8">
            <!-- Hero section -->
            <h1 class="text-3xl font-bold tracking-wide sm:text-4xl lg:text-5xl mb-6 font-serif text-center sm:text-left" transition:name="hero-heading">
                Oliver Steele
            </h1>
            <div class="flex flex-col sm:flex-row gap-6 items-start">
                <!-- Square image on the left -->
                <div class="flex-shrink-0 mx-auto sm:mx-0">
                    <div class="w-48 h-48 sm:w-56 sm:h-56 lg:w-64 lg:h-64 rounded-lg overflow-hidden">
                        <img
                            src="/images/banner-new.jpg"
                            alt="Oliver Steele"
                            class="w-full h-full object-cover object-center"
                            transition:name="hero-image"
                        />
                    </div>
                </div>

                <!-- Text content on the right -->
                <div class="flex-1 flex flex-col justify-start text-center sm:text-left">
                    <p class="text-base sm:text-lg leading-relaxed text-gray-600 dark:text-gray-300 italic max-w-xl">
                        Researcher, software engineer, educator, and maker passionate about building tools for creativity and learning.
                        Currently a graduate student at <a href="https://www.sigs.tsinghua.edu.cn/en/" target="_blank" rel="noopener noreferrer" class="link">Tsinghua Shenzhen International Graduate School (SIGS)</a>. Previously at Apple, Nest Labs, and various startups, combined with academic positions at NYU Shanghai and Franklin W. Olin College of Engineering.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 py-12">
        <div class="prose prose-lg dark:prose-invert max-w-none">
            <section class="mb-8">
                <p class="mb-6">
                    My work spans from developing core technologies at companies
                    like Apple (Quickdraw GX graphics engine) and Nest (backend
                    services for the Learning Thermostat), to creating <a
                        href="/software"
                        class="link"
                        >open-source tools and libraries</a
                    > that have inspired language features in CoffeeScript and beyond.
                    I've founded startups, led engineering teams, and hold multiple
                    patents in areas ranging from IoT systems to interactive shopping
                    experiences.
                </p>

                <p class="mb-6">
                    As an educator, I've developed and <a
                        href="/teaching/courses"
                        class="link"
                        >taught courses</a
                    > in creative coding, physical computing, software design, and
                    <a
                        href="/woodworking"
                        class="link"
                        >woodworking for art and design</a
                    >. My teaching philosophy centers on hands-on learning,
                    creative expression, and building tools that empower others
                    to create.
                </p>
            </section>

            <section class="mb-8">
                <h2 class="text-2xl font-semibold mb-4">Areas of Interest</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-4 bg-rose-50 dark:bg-rose-900/20 rounded-lg border border-rose-200/50 dark:border-rose-700/50">
                        <h3 class="font-semibold mb-2">
                            Language Models & AI Research
                        </h3>
                        <p class="text-sm text-gray-700 dark:text-gray-300">
                            As I've increasingly engaged with and <a
                                href="/software#llm-tools"
                                class="link"
                                >built tools for LLMs</a
                            >, I've become fascinated by understanding how they
                            work under the hood. This curiosity about their
                            architecture and capabilities is driving me to make
                            this a primary research focus in graduate school
                        </p>
                    </div>

                    <div class="p-4 bg-purple-50 dark:bg-purple-900/20 rounded-lg border border-purple-200/50 dark:border-purple-700/50">
                        <h3 class="font-semibold mb-2">
                            Creative & Interactive Systems
                        </h3>
                        <p class="text-sm text-gray-700 dark:text-gray-300">
                            Building software and hardware systems that enable <a
                                href="/art"
                                class="link"
                                >artistic expression</a
                            >, creative exploration, and tangible interactive
                            experiences through <a
                                href="/topics/physical-computing"
                                class="link"
                                >physical computing</a
                            > and <a
                                href="/topics/p5js"
                                class="link"
                                >creative coding</a
                            >
                        </p>
                    </div>

                    <div class="p-4 bg-sky-50 dark:bg-sky-900/20 rounded-lg border border-sky-200/50 dark:border-sky-700/50">
                        <h3 class="font-semibold mb-2">
                            Language Learning Technology
                        </h3>
                        <p class="text-sm text-gray-700 dark:text-gray-300">
                            Developing <a
                                href="/topics/language-learning"
                                class="link"
                                >tools and systems</a
                            > to enhance language acquisition through interactive
                            applications and AI-powered learning aids
                        </p>
                    </div>

                    <div class="p-4 bg-green-50 dark:bg-green-900/20 rounded-lg border border-green-200/50 dark:border-green-700/50">
                        <h3 class="font-semibold mb-2">Computer Education</h3>
                        <p class="text-sm text-gray-700 dark:text-gray-300">
                            Creating <a
                                href="/topics/computer-education"
                                class="link"
                                >resources and tools</a
                            > for teaching programming and computational thinking
                            through hands-on, project-based learning with <a
                                href="https://processing.org/"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="link"
                                >Processing</a
                            >, <a
                                href="https://p5js.org/"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="link"
                                >p5.js</a
                            >, <a
                                href="https://www.arduino.cc/"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="link"
                                >Arduino</a
                            >, and <a
                                href="https://www.espressif.com/en/products/socs/esp32"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="link"
                                >ESP32</a
                            >
                        </p>
                    </div>
                </div>
            </section>

            <section class="mb-8">
                <h2 class="text-2xl font-semibold mb-4">Recent Projects</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 not-prose">
                    {recentProjects.map((project) => (
                        <a
                            href={project.website || project.repo || "#"}
                            target={project.website || project.repo ? "_blank" : undefined}
                            rel={project.website || project.repo ? "noopener noreferrer" : undefined}
                            class="block p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 hover:shadow-md transition-all"
                        >
                            <h3 class="font-semibold text-sm mb-1">{project.name}</h3>
                            <p class="text-xs text-gray-600 dark:text-gray-400 line-clamp-2">{project.description}</p>
                            {project.primaryLanguage && (
                                <span class="inline-block mt-2 text-xs px-2 py-0.5 bg-gray-100 dark:bg-gray-800 rounded-full text-gray-600 dark:text-gray-400">
                                    {project.primaryLanguage}
                                </span>
                            )}
                        </a>
                    ))}
                </div>
            </section>

            <section>
                <h2 class="text-2xl font-semibold mb-4">Get in Touch</h2>
                <p>
                    I'm always interested in collaborating on projects related to AI research, creative tools, and education.
                    If you'd like to connect, please reach out through my <a
                        href="/contact"
                        class="link"
                        >contact page</a
                    >.
                </p>
            </section>
        </div>
    </div>
</Layout>
